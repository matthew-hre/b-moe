# Verifies the linear-signature HMAC on incoming webhooks
LINEAR_WEBHOOK_SECRET=

# GitHub
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=
BOT_GITHUB_USERNAME=

# Model
OPENROUTER_API_KEY=

# Redis
REDIS_HOST=
REDIS_PORT=6379

# Sandbox
DOCKER_HOST=local
REPO_BASE_PATH=
