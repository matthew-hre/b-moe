PORT=3000

# Linear agent (OAuth app installed with actor=app)
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=
# OAuth callback URL; defaults to the request origin + /oauth/linear/callback
LINEAR_REDIRECT_URI=
# Verifies the linear-signature HMAC on incoming webhooks
LINEAR_WEBHOOK_SECRET=

# GitHub
# Prefer GitHub App installation auth for bot-owned PRs. GITHUB_TOKEN is a fallback.
GITHUB_TOKEN=
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
# Used for git commit attribution inside sandboxes (name + username@users.noreply.github.com)
BOT_GITHUB_USERNAME=

# Model
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-3.1-flash-lite

# Pi coding agent inside the sandbox image (falls back to OPENROUTER_* when PI_* is unset)
PI_COMMAND=pi
PI_PROVIDER=
PI_MODEL=
PI_API_KEY=
PI_THINKING_LEVEL=
PI_TOOLS=read,bash,edit,write,grep,find,ls

# Redis
REDIS_HOST=
REDIS_PORT=6379

# Sandbox
DOCKER_HOST=local
SANDBOX_IMAGE=b-moe/sandbox:latest
REPO_BASE_PATH=
# Optional repository aliases for Linear guidance, e.g.
# {"frontend":"https://github.com/company/web","backend":{"url":"https://github.com/company/api","baseBranch":"main"}}
REPOSITORIES_JSON=
